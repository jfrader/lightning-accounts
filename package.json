{
  "name": "lightning-accounts",
  "version": "7.0.1",
  "description": "Lightning Accounts Server",
  "repository": "https://github.com/jfrader/lightning-accounts.git",
  "main": "dist/index.js",
  "author": "Fran <jfrader.com>",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "yarn": "1.22.22"
  },
  "keywords": [
    "bitcoin",
    "lightning",
    "satoshi",
    "api",
    "accounts",
    "custodial"
  ],
  "files": [
    "node_modules/.prisma/client/*",
    "node_modules/form-data/*",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/index.js.map",
    "dist/swagger.json"
  ],
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "build": "yarn swagger:generate && rimraf build && tsc -p tsconfig.build.json && cp -R src/static build/src/",
    "start": "nodemon",
    "start:migrate": "prisma db push && prisma db seed && yarn start",
    "start:prod": "node bin/lightning-accounts-server",
    "start:prod:migrate": "prisma migrate deploy && yarn start:prod",
    "start:test": "dotenv -e .env.test -- prisma db push --force-reset && dotenv -e .env.test -- prisma db seed && dotenv -e .env.test -- jest --ci --watchAll=false --detectOpenHandles --config ./jest.config.ts",
    "test:unit": "jest --ci --watchAll=false --config ./jest.config.ts tests/unit",
    "start:e2e": "dotenv -e .env.test -- prisma db push --force-reset && dotenv -e .env.test -- prisma db seed && dotenv -e .env.test -- nodemon",
    "lightning:payinvoice": "sudo docker compose exec -i --user lnd carol lncli -n regtest payinvoice",
    "docker": "NODE_ENV=development ./init-dev.sh",
    "docker:e2e": "NODE_ENV=test ./init-e2e.sh",
    "docker:test": "NODE_ENV=test ./init-test.sh",
    "docker:exec": "docker compose exec -i server yarn",
    "docker:prod": "NODE_ENV=production docker compose -f docker-compose.prod.yml --env-file .env build server && docker compose -f docker-compose.prod.yml --env-file .env up --no-build",
    "docker:prod:make-admin": "docker compose -f docker-compose.prod.yml --env-file .env exec -T server yarn admin:make",
    "docker:prod:migrate": "docker compose -f docker-compose.prod.yml --env-file .env run --rm --no-deps server yarn prisma migrate deploy",
    "docker:staging": "docker compose -f docker-compose.staging.yml --env-file .env build server && docker compose -f docker-compose.staging.yml --env-file .env up --no-build -d",
    "docker:staging:make-admin": "docker compose -f docker-compose.staging.yml --env-file .env exec -T server yarn admin:make",
    "docker:staging:migrate": "docker compose -f docker-compose.staging.yml --env-file .env run --rm --no-deps server yarn prisma migrate deploy",
    "admin:make": "ts-node scripts/makeAdmin.ts",
    "application:provision": "node build/src/cli/provisionApplication.js",
    "swagger:specs": "yarn prisma generate && cross-env NODE_ENV=development ts-node scripts/prismaToSwagger.ts && cross-env NODE_ENV=development ts-node scripts/swaggerToJson.ts",
    "swagger:client": "yarn swagger:specs && yarn swagger-typescript-api generate -p ./dist/swagger.json -o ./dist -n index.ts --axios",
    "swagger:generate": "yarn swagger:client && tsc -p tsconfig.dist.json",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "prepare": "husky",
    "prepublishOnly": "yarn swagger:generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" \"prisma/**/*.ts\" \"*.ts\" \"render*.yaml\" \".github/workflows/*.yml\"",
    "prettier:fix": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" \"prisma/**/*.ts\" \"*.ts\" \"render*.yaml\" \".github/workflows/*.yml\"",
    "security:audit": "yarn audit --groups dependencies"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^9.9.0",
    "@jest/globals": "^30.3.0",
    "@openapi-contrib/json-schema-to-openapi-schema": "^4.3.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.7.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.13",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.17.10",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/json-schema": "^7.0.15",
    "@types/morgan": "^1.9.3",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/passport": "^1.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-oauth2": "^1.8.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/swagger2openapi": "^7.0.4",
    "@types/xss-filters": "^1.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cross-env": "^10.0.0",
    "dotenv-cli": "^7.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.1.4",
    "node-mocks-http": "^1.12.1",
    "nodemon": "^3.1.14",
    "openapi-types": "^12.1.3",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.3",
    "supertest": "^7.1.4",
    "swagger-typescript-api": "^13.12.5",
    "swagger2openapi": "^7.0.8",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.0",
    "form-data": "^4.0.6",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "joi": "^18.2.3",
    "js-yaml": "^4.2.0",
    "lightning": "^12.2.0",
    "moment": "^2.29.4",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.3",
    "nostr-tools": "^2.7.2",
    "passport": "^0.7.0",
    "passport-cookie": "^1.0.9",
    "passport-custom": "^1.1.1",
    "passport-jwt": "^4.0.0",
    "passport-oauth1": "^1.3.0",
    "passport-oauth2": "^1.8.0",
    "passport-strategy": "^1.0.0",
    "prisma": "^6.12.0",
    "prisma-json-schema-generator": "^5.1.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.8.2",
    "xss-filters": "^1.2.7"
  },
  "peerDependencies": {
    "axios": "^1.18.1",
    "form-data": "^4.0.6"
  },
  "resolutions": {
    "@apidevtools/json-schema-ref-parser/js-yaml": "4.3.0",
    "@babel/core": "7.29.6",
    "@eslint/eslintrc/js-yaml": "4.3.0",
    "axios/form-data": "4.0.6",
    "express-rate-limit/ip-address": "10.1.1",
    "lightning/**/form-data": "2.5.6",
    "protobufjs": "7.6.3",
    "qs": "6.15.2",
    "superagent/form-data": "4.0.6",
    "swagger-jsdoc/**/brace-expansion": "5.0.7",
    "swagger-jsdoc/**/fast-uri": "3.1.3",
    "swagger-jsdoc/**/js-yaml": "4.3.0"
  }
}
