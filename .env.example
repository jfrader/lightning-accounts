NODE_ENV=development
NODE_PORT=2999
NODE_ORIGIN="http://localhost:3000"
NODE_DOMAIN=
NODE_HOST="http://localhost:3000"
# Number of trusted reverse-proxy hops. Keep 0 unless the deployment has a known proxy chain.
NODE_TRUST_PROXY_HOPS=0
# Optional comma-separated proxy IPs/CIDRs when an IP allowlist is preferable to hop count.
NODE_TRUSTED_PROXY_IP=
NODE_DEBUG_LEVEL=info

# Comma-separated application service-account emails. The account password is still required.
APPLICATION_EMAILS="admin@example.com"
# Optional source address restriction; leave empty when cloud source addresses are dynamic.
APPLICATION_ADDRESS=

NODE_DB_NAME="lnaccounts_local"
NODE_DB_USER="lnaccounts_user"
NODE_DB_PASSWORD="lnaccounts_password"

# Overwritten by docker using credentials above
DATABASE_URL="postgresql://lnaccounts_user:lnaccounts_password@localhost:5432/lnaccounts_local?schema=public"

# X / Twitter authentication
#
# /v1/auth/twitter uses OAuth 1.0a "Sign in with X" because X returns user_id
# during the token exchange and does not require an extra API v2 profile lookup.
# Use the App's "API Key and Secret" values from the X Developer Portal.
TWITTER_API_KEY=""
TWITTER_API_SECRET=""

# /v1/auth/x uses OAuth 2.0 Authorization Code + PKCE.
# Use the App's "OAuth 2.0 Client ID and Client Secret" values.
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
TWITTER_CLIENT_TYPE="confidential"

SEED_HASH_SECRET="replace-with-a-long-random-secret"

# JWT
JWT_COOKIE_PREFIX=
JWT_SECRET="replace-with-a-long-random-cookie-signing-secret"
JWT_BASE64_PUBLIC_KEY="base64-encoded-rsa-public-key"
JWT_BASE64_PRIVATE_KEY="base64-encoded-rsa-private-key"
BCRYPT_ROUNDS=12

# Number of minutes after which an access token expires
JWT_ACCESS_EXPIRATION_MINUTES=30
# Number of days after which a refresh token expires
JWT_REFRESH_EXPIRATION_DAYS=30
# Number of minutes after which a reset password token expires
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
# Number of minutes after which a verify email token expires
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10
# Number of minutes after which a magic login link expires
JWT_MAGIC_LINK_EXPIRATION_MINUTES=10

# SMTP configuration options for the email service
SMTP_HOST=email-server
SMTP_PORT=587
SMTP_USERNAME=email-server-username
SMTP_PASSWORD=email-server-password
EMAIL_FROM=support@yourapp.com

# LND Lightning daemon configuration
# For testing, you can use a lightning simulator like Polar: https://lightningpolar.com/
WALLET_ENABLED=0
LND_CERT="base 64 encoded tls.cert"
LND_ADMIN_MACAROON="base 64 encoded admin.macaroon"
LND_SOCKET="127.0.0.1:10001"

WALLET_LIMIT=100000
